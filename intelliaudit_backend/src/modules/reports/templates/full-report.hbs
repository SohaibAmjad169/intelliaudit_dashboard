<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ASHRAE Level II Energy Audit, Water Audit & Retro-commissioning Report</title>
  <style>
    @page {
      size: A4;
      margin: 0;
    }

    body {
      font-family: Arial, Helvetica, sans-serif;
      font-size: 11pt;
      line-height: 1.4;
      color: #333;
      margin: 0;
      padding: 0;
    }

    h1 {
      font-size: 18pt;
      color: #4d9b58;
      margin-top: 20px;
      margin-bottom: 10px;
      page-break-after: avoid;
    }

    h2 {
      font-size: 14pt;
      color: #4A4A4A;
      margin-top: 15px;
      margin-bottom: 8px;
      page-break-after: avoid;
    }

    h3 {
      font-size: 12pt;
      color: #4A4A4A;
      margin-top: 12px;
      margin-bottom: 6px;
      page-break-after: avoid;
    }

    h4 {
      font-size: 11pt;
      color: #4A4A4A;
      margin-top: 10px;
      margin-bottom: 5px;
      page-break-after: avoid;
    }

    p {
      margin-bottom: 8px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 15px;
    }

    th {
      background-color: #e6f2e6;
      color: #4A4A4A;
      font-weight: bold;
      text-align: left;
      padding: 8px;
      border: 1px solid #CCCCCC;
    }

    td {
      padding: 8px;
      border: 1px solid #CCCCCC;
    }

    tr:nth-child(even) {
      background-color: #f9f9f9;
    }

    .text-right {
      text-align: right;
    }

    .text-center {
      text-align: center;
    }

    .page-break {
      page-break-before: always;
      padding: 0.8cm;
    }

    .cover-page {
      width: 100%;
      height: 100vh;
      display: flex;
      position: relative;
      overflow: hidden;
    }

    .cover-left {
      width: 60%;
      height: 100%;
      background-color: white;
      padding: 50px;
      box-sizing: border-box;
      display: flex;
      flex-direction: column;
    }

    .cover-right {
      width: 40%;
      height: 100%;
      background-color: #e0e0e0;
      padding: 50px;
      box-sizing: border-box;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .logo {
      width: 180px;
      margin-bottom: 20px;
    }

    .green-banner {
      position: absolute;
      top: 28%;
      left: 0;
      width: 85%;
      background-color: #4d9b58;
      color: white;
      font-family: Cambria, serif;
      padding: 25px 0;
      text-align: center;
      z-index: 10;
    }

    .banner-title {
      font-size: 28px;
      font-weight: bold;
      margin: 0;
      line-height: 1.3;
      padding: 0 50px;
    }

    .building-image-container {
      position: absolute;
      top: 55%;
      left: 50%;
      transform: translate(-50%, -30%);
      width: 60%;
      z-index: 20;
      background-color: white;
      padding: 10px;
      border: 1px solid #999;
      box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
    }

    .building-image {
      width: 100%;
      height: auto;
      display: block;
      border: none;
    }

    .address-title {
      font-size: 18px;
      font-weight: bold;
      margin: 0 0 10px 0;
      color: #000;
    }

    .address-text {
      font-size: 12px;
      margin: 0 0 20px 0;
      color: #333;
    }

    .building-id {
      font-size: 12px;
      font-weight: bold;
      margin: 0 0 10px 0;
    }

    .report-date {
      font-size: 12px;
      font-weight: bold;
      margin: 0;
    }

    .prepared-by {
      margin-top: auto;
    }

    .prepared-by-title {
      font-size: 12px;
      font-weight: bold;
      margin: 0 0 5px 0;
    }

    .company-name {
      font-size: 11px;
      font-weight: bold;
      margin: 0 0 5px 0;
    }

    .company-info {
      font-size: 11px;
      margin: 0 0 5px 0;
    }

    .toc-item {
      display: flex;
      justify-content: space-between;
      margin-bottom: 5px;
    }

    .toc-dots {
      flex-grow: 1;
      height: 1px;
      position: relative;
      margin: 0 5px;
    }

    .toc-dots::after {
      content: "";
      position: absolute;
      bottom: 7px;
      left: 0;
      right: 0;
      height: 1px;
      border-bottom: 1px dotted #aaa;
    }

    /* Style for main section entry lines */
    .toc-item:nth-child(1) .toc-dots::after,
    .toc-item:nth-child(7) .toc-dots::after,
    .toc-item:nth-child(18) .toc-dots::after,
    .toc-item:nth-child(29) .toc-dots::after,
    .toc-item:nth-child(40) .toc-dots::after {
      border-bottom: 2px dotted #000;
    }

    /* Additional styling for different section types */
    .toc-item:not(:nth-child(1)):not(:nth-child(7)):not(:nth-child(18)):not(:nth-child(29)):not(:nth-child(40)) .toc-dots::after {
      bottom: 7px;
    }

    .superscript {
      vertical-align: super;
      font-size: smaller;
    }

    /* Table of Contents Styling */
    .toc-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 20px;
      border-bottom: 1px solid #ddd;
      padding-bottom: 8px;
    }

    .toc-title h1 {
      color: #00b050;
      margin-top: 0;
      font-size: 24pt;
      margin-bottom: 5px;
    }

    /* Add the header line above the TOC */
    .toc-header-line {
      font-size: 9pt;
      color: #666;
      text-align: center;
      margin-bottom: 15px;
      border-bottom: 1px solid #eee;
      padding-bottom: 5px;
    }

    .toc-logo {
      margin-top: 10px;
    }

    .toc-logo img {
      width: 140px;
    }

    .toc-content {
      font-size: 10pt;
      padding: 0 15px;
      max-width: 95%;
      margin: 0 auto;
    }

    /* Style the TOC items */
    .toc-item {
      display: flex;
      align-items: baseline;
      margin-bottom: 4px;
      line-height: 1.5;
      width: 100%;
      white-space: nowrap;
    }

    /* Main section styling (I, II, III, IV, V) */
    .toc-item:nth-child(1) .toc-section,
    .toc-item:nth-child(7) .toc-section,
    .toc-item:nth-child(18) .toc-section,
    .toc-item:nth-child(29) .toc-section,
    .toc-item:nth-child(40) .toc-section {
      font-weight: bold;
      color: #000;
      font-style: italic;
    }

    .toc-item:nth-child(1) .toc-text,
    .toc-item:nth-child(7) .toc-text,
    .toc-item:nth-child(18) .toc-text,
    .toc-item:nth-child(29) .toc-text,
    .toc-item:nth-child(40) .toc-text {
      font-weight: bold;
      font-style: italic;
      color: #000;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    /* Main section dots styling */
    .toc-item:nth-child(1) .toc-dots::after,
    .toc-item:nth-child(7) .toc-dots::after,
    .toc-item:nth-child(18) .toc-dots::after,
    .toc-item:nth-child(29) .toc-dots::after,
    .toc-item:nth-child(40) .toc-dots::after {
      border-bottom: 2px dotted #000;
      bottom: 7px;
    }

    .toc-item:nth-child(1),
    .toc-item:nth-child(7),
    .toc-item:nth-child(18),
    .toc-item:nth-child(29),
    .toc-item:nth-child(40) {
      margin-top: 10px;
      margin-bottom: 6px;
    }

    /* Subsection styling (A, B, C, etc.) */
    .toc-section {
      width: 25px;
      font-weight: normal;
      color: #333;
      padding-right: 2px;
    }

    .toc-text {
      flex-shrink: 0;
      color: #333;
      margin-right: 4px;
      padding-right: 3px;
    }

    .toc-page {
      text-align: right;
      width: 25px;
      flex-shrink: 0;
      padding-left: 2px;
    }

    /* Indent level for subsections */
    .toc-item:not(:nth-child(1)):not(:nth-child(7)):not(:nth-child(18)):not(:nth-child(29)):not(:nth-child(40)) .toc-section {
      margin-left: 10px;
    }

    /* Add spacing after the last subsection of each major section */
    .toc-item:nth-child(6),
    .toc-item:nth-child(17),
    .toc-item:nth-child(28),
    .toc-item:nth-child(39) {
      margin-bottom: 12px;
    }

    /* Adjust space between TOC and Executive Summary */
    #executive-summary {
      margin-top: 0.5cm;
    }
  </style>
</head>

<body>
  <!-- Cover Page -->
