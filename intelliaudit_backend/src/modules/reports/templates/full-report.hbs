    <div class="building-image-container">
      {{#if project.satellite_image_url}}
      <img class="building-image" src="https://iili.io/3GLCNbj.png" alt="Building Image">
      {{else}}
      <img class="building-image" src="https://iili.io/3GLCNbj.png" alt="Building Image" style="max-height:300px;">
      {{/if}}
    </div>
  </div>

