        <p class="building-id">Building ID: {{project.id}}</p>
        <p class="report-date">April 17<span class="superscript">th</span>, 2025</p>
      </div>

      <div class="prepared-by">
        <p class="prepared-by-title">Prepared by:</p>
        <p class="company-name">Vert Energy Group, Inc.</p>
        <p class="company-info">100 Spectrum Center Drive</p>
        <p class="company-info">Irvine, California, 92618</p>
        <p class="company-info">Phone: (800) 585-2680</p>
        <p class="company-info">Email: info@vertenergygroup.com</p>
      </div>
    </div>

    <div class="green-banner">
      <p class="banner-title">ASHRAE Level II Energy Audit,</p>
      <p class="banner-title">Water Audit</p>
      <p class="banner-title">& Retro-commissioning Report</p>
